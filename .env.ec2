# Configuración de email (si usas notificaciones)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu_email@gmail.com
EMAIL_PASSWORD=tu_app_password

# ===================================
# PASOS PARA CONFIGURAR EN EC2:
# ===================================

# 1. Reemplazar TU-IP-PUBLICA-EC2 por la IP real de tu instancia
# 2. Configurar Security Groups para abrir puertos 3000 y 5173
# 3. Opcional: Configurar dominio con Route 53
# 4. Opcional: Certificado SSL con Let's Encrypt
