# 🔧 CAMBIAR estas URLs por las de tu EC2:
# Opción 1: IP pública de EC2
FRONTEND_URL=http://TU-IP-PUBLICA-EC2:5173

# Opción 2: Dominio personalizado (recomendado)
# FRONTEND_URL=https://tu-dominio.com

# Configuración adicional para EC2
SESSION_SECRET=tu_session_secret_muy_seguro_para_ec2

# SSL en producción (opcional)
